# ── Server (Hono API) ───────────────────────────────────────────────────────
# All optional in local dev — server/env.ts falls back to the local
# `supabase start` instance and a dev-only auth secret.

# Postgres connection. Local: supabase start prints this (db port 55322).
# Production (Vercel): use the Supabase *transaction pooler* URL (port 6543).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres

# Generate with: openssl rand -base64 32   (REQUIRED in production)
BETTER_AUTH_SECRET=

# Public origin the API is served from (REQUIRED in production,
# e.g. https://my-pact.vercel.app)
BETTER_AUTH_URL=http://localhost:8787

# Comma-separated browser origins allowed by CORS / Better Auth trustedOrigins.
CORS_ORIGINS=http://localhost:8081,http://localhost:8090,http://localhost:19006

# ── Social login (scaffolded — fill these to activate) ─────────────────────
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Apple: https://developer.apple.com/account/resources/identifiers
# APPLE_CLIENT_SECRET is the signed JWT, see docs/backend-setup.md
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_APP_BUNDLE_IDENTIFIER=

# ── Client (Expo) ───────────────────────────────────────────────────────────
# Where the app finds the API. Unset = offline demo mode (mock auth, seeded
# data). On a physical device use your machine's LAN IP, not localhost.
EXPO_PUBLIC_API_URL=http://localhost:8787
